PORT=4321
NODE_ENV=development

# Production deployments must set both values to strong, unique random secrets.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Public canonical URL used by RSS, sitemap, Open Graph and JSON-LD.
PUBLIC_SITE_URL=http://localhost:4321

# Put this on a persistent volume in production so uploaded images survive deploys.
BLOG_UPLOAD_DIR=./fullstack/uploads
